# Copy this file to .env and fill in your values
# NEVER commit .env to Git

# Get your key from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional: If you upgrade to Pinecone for vector search
# PINECONE_API_KEY=your-pinecone-key-here
# PINECONE_INDEX_NAME=landscape-knowledge

# Optional: SingleOps API (for real crew/job data)
# SINGLEOPS_API_KEY=your-singleops-key-here
# SINGLEOPS_BASE_URL=https://api.singleops.com/v1

# Optional: LMN API (for real pricing data)
# LMN_API_KEY=your-lmn-key-here
